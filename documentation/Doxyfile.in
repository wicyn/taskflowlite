# Doxyfile configuration for TaskflowLite

PROJECT_NAME = "TaskflowLite"
PROJECT_NUMBER = 1.0.0
PROJECT_BRIEF = "A high-performance, header-only, C++23 task scheduling engine"
OUTPUT_DIRECTORY = @CMAKE_CURRENT_BINARY_DIR@/doxygen
CREATE_SUBDIRS = NO

# Header-only library settings
INPUT = @CMAKE_CURRENT_SOURCE_DIR@/../include
FILE_PATTERNS = *.hpp
RECURSIVE = YES
EXCLUDE = 
EXCLUDE_PATTERNS = 

# Output format
GENERATE_HTML = YES
GENERATE_LATEX = NO
GENERATE_MAN = NO
GENERATE_XML = NO
GENERATE_DOCBOOK = NO

# HTML output settings
HTML_OUTPUT = html
HTML_FILE_EXTENSION = .html
HTML_HEADER = 
HTML_FOOTER = 
HTML_STYLESHEET = 
HTML_EXTRA_STYLESHEET = 
HTML_EXTRA_FILES = 

# Doxygen settings
EXTRACT_ALL = YES
EXTRACT_PRIVATE = YES
EXTRACT_PACKAGE = YES
EXTRACT_STATIC = YES
EXTRACT_LOCAL_METHODS = YES

# Include settings
INCLUDE_PATH = 
INCLUDE_FILE_PATTERNS = 
PREDEFINED = 
EXPAND_AS_DEFINED = 

# Source browsing
SOURCE_BROWSER = YES
INLINE_SOURCES = NO
STRIP_FROM_PATH = 

# Preprocessor
ENABLE_PREPROCESSING = YES
MACRO_EXPANSION = NO
EXPAND_ONLY_PREDEF = NO
SEARCH_INCLUDES = YES

# Relations
HAVE_DOT = NO
CLASS_GRAPH = YES
COLLABORATION_GRAPH = YES
GROUP_GRAPHS = YES

# Call graphs
CALLER_GRAPH = NO
CALL_GRAPH = NO

# Graphical options
DOT_IMAGE_FORMAT = svg
INTERACTIVE_SVG = NO
DOT_PATH = 
DOTFILE_DIRS = 

# Layout
LAYOUT_FILE = 
